# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001

# Database
DATABASE_URL=postgresql://taurus:root@localhost:5432/taurus_db

# Redis (use REDIS_URL for managed services like Railway, or host/port for local)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=a6b86547d517159bf43d88898ad6ec841d152617fce40c3030855aee431e2664
JWT_REFRESH_SECRET=d96123f2a5433b4547f5cc20b7b1c953e9717fd475cad1d67ab63c4acf24644c
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Resend (Email Auth)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ─── Integration OAuth Credentials ──────────────────────
# Register an OAuth app with each provider and paste its Client ID / Secret
# below. Redirect URI for each app should be your frontend Settings page
# (e.g. http://localhost:3001/settings). Only providers whose credentials
# are filled in will appear as "Connect"-able in Settings → Integrations.

# Slack — api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Google (Drive) — console.cloud.google.com → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Jira — developer.atlassian.com → OAuth 2.0 (3LO) app
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Notion — notion.so/my-integrations → Public integration
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# HubSpot — app.hubspot.com → Developer → Apps
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Salesforce — Setup → App Manager → New Connected App
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
