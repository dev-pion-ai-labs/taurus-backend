generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
}

enum TemplateType {
  BASE
  INDUSTRY
}

enum TemplateStatus {
  GENERATING
  ACTIVE
  DEPRECATED
}

enum QuestionType {
  TEXT
  SINGLE_CHOICE
  MULTI_CHOICE
  SCALE
}

enum SessionStatus {
  PENDING_TEMPLATE
  IN_PROGRESS
  COMPLETED
  ABANDONED
  FAILED
}

enum ReportStatus {
  GENERATING
  COMPLETED
  FAILED
}

enum QuestionSection {
  BASE
  INDUSTRY
  CHALLENGE_BONUS
  PERSONALIZED
  ADAPTIVE
}

enum ActionStatus {
  BACKLOG
  THIS_SPRINT
  IN_PROGRESS
  AWAITING_APPROVAL
  DEPLOYED
  VERIFIED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EstimatedEffort {
  HOURS
  DAYS
  WEEKS
  MONTHS
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

enum ToolCategory {
  AI_PLATFORM
  AUTOMATION
  ANALYTICS
  CRM
  COMMUNICATION
  DEVELOPMENT
  SECURITY
  INDUSTRY_SPECIFIC
  OTHER
}

enum ToolSource {
  ONBOARDING
  CONSULTATION
  DISCOVERY
  RECOMMENDATION
  MANUAL
}

enum ToolStatus {
  IDENTIFIED
  EVALUATING
  ACTIVE
  DEPRECATED
}

enum DeploymentPlanStatus {
  DRAFT
  PLANNING
  PLAN_READY
  APPROVED
  EXECUTING
  COMPLETED
  FAILED
}

enum ArtifactType {
  IMPLEMENTATION_GUIDE
  CONFIGURATION_TEMPLATE
  INTEGRATION_CHECKLIST
  VENDOR_EVALUATION
  CODE_SNIPPET
  CUSTOM
}

enum IntegrationProvider {
  SLACK
  GOOGLE_DRIVE
  MICROSOFT_TEAMS
  JIRA
  SALESFORCE
  HUBSPOT
  ZAPIER
  NOTION
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
  ERROR
}

// ─── Models ──────────────────────────────────────────────

model Industry {
  id            String   @id @default(uuid())
  name          String
  normalizedKey String   @unique @map("normalized_key")
  aliases       String[] @default([])
  createdAt     DateTime @default(now()) @map("created_at")

  organizations Organization[]
  templates     ConsultationTemplate[]

  @@map("industries")
}

model Organization {
  id         String   @id @default(uuid())
  name       String
  industryId String   @map("industry_id")
  size       String?
  /// Cached starter consultation questions for the NEXT org follow-up
  /// consultation. Populated by a background job chained after the prior
  /// session's report finishes generating, so the user's next consultation
  /// skips the live-generation wait. Shape:
  /// { generatedFor: <sourceSessionId>, questions: Array<{questionText, questionType, options}> }.
  preGeneratedQuestions Json?     @map("pre_generated_questions")
  preGeneratedAt        DateTime? @map("pre_generated_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  industry    Industry              @relation(fields: [industryId], references: [id])
  users       User[]
  sessions    ConsultationSession[]
  onboarding  Onboarding?
  departments Department[]
  reports          TransformationReport[]
  trackerActions   TransformationAction[]
  sprints          Sprint[]
  discoveryReports DiscoveryReport[]
  toolEntries      ToolEntry[]
  toolSpendRecords ToolSpendRecord[]
  deploymentPlans  DeploymentPlan[]
  integrations     IntegrationConnection[]

  @@index([industryId])
  @@map("organizations")
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  firstName           String?  @map("first_name")
  lastName            String?  @map("last_name")
  role                Role     @default(MEMBER)
  organizationId      String?  @map("organization_id")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization  Organization?        @relation(fields: [organizationId], references: [id])
  refreshTokens RefreshToken[]
  sessions      ConsultationSession[]
  otpCodes      OtpCode[]
  assignedActions  TransformationAction[] @relation("ActionAssignee")
  actionComments   ActionComment[]
  deploymentPlans  DeploymentPlan[]
  integrations     IntegrationConnection[]

  @@index([organizationId])
  @@map("users")
}

model OtpCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  code      String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("otp_codes")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ConsultationTemplate {
  id           String         @id @default(uuid())
  type         TemplateType
  status       TemplateStatus @default(GENERATING)
  version      Int            @default(1)
  industryId   String?        @map("industry_id")
  aiModel      String?        @map("ai_model")
  aiPromptHash String?        @map("ai_prompt_hash")
  generatedAt  DateTime?      @map("generated_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  industry  Industry?          @relation(fields: [industryId], references: [id])
  questions TemplateQuestion[]

  baseSessions     ConsultationSession[] @relation("BaseTemplate")
  industrySessions ConsultationSession[] @relation("IndustryTemplate")

  @@unique([type, industryId, version])
  @@map("consultation_templates")
}

model TemplateQuestion {
  id           String       @id @default(uuid())
  templateId   String       @map("template_id")
  questionText String       @map("question_text")
  questionType QuestionType @map("question_type")
  options      Json?
  orderIndex   Int          @map("order_index")
  isRequired   Boolean      @default(true) @map("is_required")
  metadata     Json?
  createdAt    DateTime     @default(now()) @map("created_at")

  template       ConsultationTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  challengeAreas QuestionChallengeArea[]
  sessionQuestions SessionQuestion[]

  @@index([templateId, orderIndex])
  @@map("template_questions")
}

model ChallengeArea {
  id            String   @id @default(uuid())
  name          String
  normalizedKey String   @unique @map("normalized_key")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  questions QuestionChallengeArea[]

  @@map("challenge_areas")
}

model QuestionChallengeArea {
  questionId      String @map("question_id")
  challengeAreaId String @map("challenge_area_id")

  question      TemplateQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  challengeArea ChallengeArea    @relation(fields: [challengeAreaId], references: [id], onDelete: Cascade)

  @@id([questionId, challengeAreaId])
  @@map("question_challenge_areas")
}

enum ConsultationScope {
  ORG
  DEPARTMENT
  WORKFLOW
}

model ConsultationSession {
  id                 String            @id @default(uuid())
  organizationId     String            @map("organization_id")
  userId             String            @map("user_id")
  status             SessionStatus     @default(PENDING_TEMPLATE)
  scope              ConsultationScope @default(ORG)
  departmentId       String?           @map("department_id")
  workflowId         String?           @map("workflow_id")
  baseTemplateId     String            @map("base_template_id")
  industryTemplateId String?           @map("industry_template_id")
  startedAt          DateTime          @default(now()) @map("started_at")
  completedAt        DateTime?         @map("completed_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  organization     Organization         @relation(fields: [organizationId], references: [id])
  user             User                 @relation(fields: [userId], references: [id])
  department       Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  workflow         Workflow?            @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  baseTemplate     ConsultationTemplate @relation("BaseTemplate", fields: [baseTemplateId], references: [id])
  industryTemplate ConsultationTemplate? @relation("IndustryTemplate", fields: [industryTemplateId], references: [id])
  questions        SessionQuestion[]
  report           TransformationReport?
  trackerActions   TransformationAction[]

  @@index([organizationId])
  @@index([status])
  @@index([organizationId, scope])
  @@index([departmentId])
  @@index([workflowId])
  @@map("consultation_sessions")
}

model SessionQuestion {
  id         String          @id @default(uuid())
  sessionId  String          @map("session_id")
  questionId String?         @map("question_id")
  section    QuestionSection
  orderIndex Int             @map("order_index")
  answer     Json?
  answeredAt DateTime?       @map("answered_at")
  skipped    Boolean         @default(false)

  // Adaptive question fields (used when questionId is null)
  isAdaptive      Boolean  @default(false) @map("is_adaptive")
  adaptiveText    String?  @map("adaptive_text")
  adaptiveType    String?  @map("adaptive_type")
  adaptiveOptions Json?    @map("adaptive_options")

  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  session  ConsultationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question TemplateQuestion?   @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@index([sessionId, orderIndex])
  @@map("session_questions")
}

// ─── Transformation Report ──────────────────────────────

model TransformationReport {
  id                   String       @id @default(uuid())
  sessionId            String       @unique @map("session_id")
  organizationId       String       @map("organization_id")
  status               ReportStatus @default(GENERATING)

  // Scores (legacy; populated by mapper for backward-compatible frontend)
  overallScore         Int?         @map("overall_score")
  maturityLevel        String?      @map("maturity_level")

  // Financial (legacy totals; superseded by ranged fields below)
  totalEfficiencyValue Float?       @map("total_efficiency_value")
  totalGrowthValue     Float?       @map("total_growth_value")
  totalAiValue         Float?       @map("total_ai_value")

  // Briefing framing (new)
  companyType          String?      @map("company_type")
  primaryAudience      String?      @map("primary_audience")
  reportGoal           String?      @map("report_goal")
  thesis               String?      @db.Text
  bigMove              String?      @map("big_move") @db.Text

  // Ranged value (new)
  totalAiValueLow      Float?       @map("total_ai_value_low")
  totalAiValueHigh     Float?       @map("total_ai_value_high")
  confidenceNote       String?      @map("confidence_note")

  // Structured content (JSON) — legacy
  executiveSummary     Json?        @map("executive_summary")
  departmentScores     Json?        @map("department_scores")
  recommendations      Json?
  implementationPlan   Json?        @map("implementation_plan")

  // Structured content (JSON) — new briefing shape
  snapshot             Json?        @map("snapshot")
  executiveBrief       Json?        @map("executive_brief")
  decisionBlocks       Json?        @map("decision_blocks")
  assumptionsAndLimits Json?        @map("assumptions_and_limits")
  peerContext          Json?        @map("peer_context")

  generatedAt          DateTime?    @map("generated_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  session      ConsultationSession @relation(fields: [sessionId], references: [id])
  organization Organization        @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("transformation_reports")
}

// ─── Department & Workflow Mapping ───────────────────────

enum AutomationLevel {
  NONE
  LOW
  MODERATE
  HIGH
  FULL
}

enum WorkflowPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Department {
  id                    String    @id @default(uuid())
  organizationId        String    @map("organization_id")
  name                  String
  headcount             Int?
  avgSalary             Float?    @map("avg_salary")
  notes                 String?   @db.Text
  /// Cached starter consultation questions generated when this department was
  /// created/updated. Used to skip the PENDING wait when a user starts a
  /// scoped consultation. Shape: Array<{questionText, questionType, options}>.
  preGeneratedQuestions Json?     @map("pre_generated_questions")
  preGeneratedAt        DateTime? @map("pre_generated_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflows            Workflow[]
  consultationSessions ConsultationSession[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("departments")
}

model Workflow {
  id                    String           @id @default(uuid())
  departmentId          String           @map("department_id")
  name                  String
  description           String?          @db.Text
  weeklyHours           Float?           @map("weekly_hours")
  peopleInvolved        Int?             @map("people_involved")
  automationLevel       AutomationLevel  @default(NONE) @map("automation_level")
  painPoints            String?          @map("pain_points") @db.Text
  priority              WorkflowPriority @default(MEDIUM)
  /// Cached starter consultation questions — see Department.preGeneratedQuestions.
  preGeneratedQuestions Json?            @map("pre_generated_questions")
  preGeneratedAt        DateTime?        @map("pre_generated_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  department           Department            @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  consultationSessions ConsultationSession[]

  @@index([departmentId])
  @@map("workflows")
}

// ─── Onboarding ─────────────────────────────────────────

model Onboarding {
  id             String  @id @default(uuid())
  organizationId String  @unique @map("organization_id")
  currentStep    Int     @default(1) @map("current_step")
  completed      Boolean @default(false)

  // Step 1: Basic Info
  companyName    String? @map("company_name")
  companyUrl     String? @map("company_url")
  industryId     String? @map("industry_id")
  customIndustry String? @map("custom_industry")
  companySize    String? @map("company_size")

  // Step 2: Business Context
  businessDescription String? @map("business_description") @db.Text
  revenueStreams      String? @map("revenue_streams") @db.Text

  // Step 3: Challenges
  selectedChallenges String[] @default([]) @map("selected_challenges")
  customChallenges   String?  @map("custom_challenges") @db.Text

  // Step 4: Data Availability
  availableData     String[] @default([]) @map("available_data")
  customDataSources String?  @map("custom_data_sources") @db.Text

  // Step 6: Tools/Tech Stack
  selectedTools String[] @default([]) @map("selected_tools")
  customTools   String?  @map("custom_tools")

  // Step 7: Goals
  selectedGoals String[] @default([]) @map("selected_goals")
  customGoals   String?  @map("custom_goals") @db.Text

  // Cached AI insights (regenerated when profile changes)
  aiInsights Json?     @map("ai_insights")
  insightsAt DateTime? @map("insights_at")

  // Scraped website content
  scrapedContent Json?     @map("scraped_content")
  scrapedAt     DateTime? @map("scraped_at")
  scrapingStatus String?  @default("NOT_STARTED") @map("scraping_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id])
  documents    OnboardingDocument[]

  @@map("onboardings")
}

model OnboardingDocument {
  id           String   @id @default(uuid())
  onboardingId String   @map("onboarding_id")
  name         String
  type         String
  size         Int
  storagePath  String   @map("storage_path")
  url          String?
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  onboarding Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@map("onboarding_documents")
}

// ─── Transformation Tracker (Module 5) ──────────────────

model TransformationAction {
  id                     String          @id @default(uuid())
  organizationId         String          @map("organization_id")
  sessionId              String?         @map("session_id")
  sourceRecommendationId String?         @map("source_recommendation_id")

  title                  String
  description            String?         @db.Text
  department             String?
  category               String?         // EFFICIENCY | GROWTH | EXPERIENCE | INTELLIGENCE

  status                 ActionStatus    @default(BACKLOG)
  assigneeId             String?         @map("assignee_id")
  priority               ActionPriority  @default(MEDIUM)

  estimatedValue         Float?          @map("estimated_value")
  actualValue            Float?          @map("actual_value")
  estimatedEffort        EstimatedEffort? @map("estimated_effort")
  phase                  Int?

  orderIndex             Int             @default(0) @map("order_index")
  dueDate                DateTime?       @map("due_date")
  startedAt              DateTime?       @map("started_at")
  deployedAt             DateTime?       @map("deployed_at")
  verifiedAt             DateTime?       @map("verified_at")
  blockerNote            String?         @map("blocker_note") @db.Text

  sprintId               String?         @map("sprint_id")

  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session      ConsultationSession? @relation(fields: [sessionId], references: [id])
  assignee     User?                @relation("ActionAssignee", fields: [assigneeId], references: [id])
  sprint          Sprint?              @relation(fields: [sprintId], references: [id])
  comments        ActionComment[]
  deploymentPlans DeploymentPlan[]

  @@index([organizationId, status])
  @@index([sprintId])
  @@map("transformation_actions")
}

model Sprint {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  number         Int
  startDate      DateTime     @map("start_date")
  endDate        DateTime     @map("end_date")
  goal           String?      @db.Text
  status         SprintStatus @default(PLANNING)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actions      TransformationAction[]

  @@index([organizationId])
  @@map("sprints")
}

model ActionComment {
  id        String   @id @default(uuid())
  actionId  String   @map("action_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  action TransformationAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User                 @relation(fields: [userId], references: [id])

  @@index([actionId])
  @@map("action_comments")
}

// ─── AI Discovery (Module 1) ───────────────────────────

model DiscoveryReport {
  id             String       @id @default(uuid())
  url            String
  domain         String
  email          String?
  organizationId String?      @map("organization_id")

  // Results
  score          Int?
  maturityLevel  String?      @map("maturity_level")
  industry       String?
  companySize    String?      @map("company_size")
  techStack      Json?        @map("tech_stack")
  aiSignals      Json?        @map("ai_signals")
  summary        String?      @db.Text
  recommendations Json?

  // Metadata
  status         ReportStatus @default(GENERATING)
  scrapedData    Json?        @map("scraped_data")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([domain])
  @@index([organizationId])
  @@map("discovery_reports")
}

// ─── AI Stack Intelligence (Module 6) ──────────────────

model ToolEntry {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")

  name           String
  category       ToolCategory @default(OTHER)
  source         ToolSource   @default(MANUAL)
  sourceId       String?      @map("source_id")

  status         ToolStatus   @default(IDENTIFIED)
  departmentIds  Json?        @map("department_ids")
  monthlyCost    Float?       @map("monthly_cost")
  userCount      Int?         @map("user_count")
  rating         Int?
  notes              String?      @db.Text
  utilizationPercent Int?         @map("utilization_percent")
  contractStartDate  DateTime?    @map("contract_start_date")
  contractEndDate    DateTime?    @map("contract_end_date")
  renewalAlertDays   Int?         @default(30) @map("renewal_alert_days")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  spendRecords   ToolSpendRecord[]

  @@unique([organizationId, name])
  @@index([organizationId, category])
  @@map("tool_entries")
}

model ToolSpendRecord {
  id             String       @id @default(uuid())
  toolEntryId    String       @map("tool_entry_id")
  organizationId String       @map("organization_id")
  month          DateTime
  amount         Float
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")

  toolEntry      ToolEntry    @relation(fields: [toolEntryId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([toolEntryId, month])
  @@index([organizationId, month])
  @@map("tool_spend_records")
}

// ─── Implementation Engine (Module 4) ─────────────────

model DeploymentPlan {
  id             String               @id @default(uuid())
  organizationId String               @map("organization_id")
  actionId       String               @map("action_id")
  userId         String               @map("user_id")

  status         DeploymentPlanStatus @default(DRAFT)
  title          String
  summary        String?              @db.Text

  conversationHistory Json?           @map("conversation_history")
  steps               Json?           // [{ stepNumber, title, description, estimatedDuration, dependencies[] }]
  prerequisites       Json?           // string[]
  risks               Json?           // [{ risk, mitigation, severity }]
  estimatedDuration   String?         @map("estimated_duration")
  suggestedArtifacts  Json?           @map("suggested_artifacts") // ArtifactType[]
  deploymentSteps     Json?           @map("deployment_steps")    // [{ provider, tool, params, dependsOn?, description? }] — consumed by PlanExecutor at deploy time

  approvedAt     DateTime?            @map("approved_at")
  approvedBy     String?              @map("approved_by")
  rejectionNote  String?              @map("rejection_note") @db.Text
  completedAt    DateTime?            @map("completed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  action         TransformationAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id])
  artifacts      DeploymentArtifact[]

  @@index([organizationId])
  @@index([actionId])
  @@map("deployment_plans")
}

model DeploymentArtifact {
  id             String       @id @default(uuid())
  planId         String       @map("plan_id")
  type           ArtifactType
  title          String
  content        String       @db.Text
  metadata       Json?
  checklistState Json?        @map("checklist_state") // { [lineIndex: number]: boolean }
  orderIndex     Int          @default(0) @map("order_index")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  plan       DeploymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("deployment_artifacts")
}

// ─── Integrations ────────────────────────────────────────

model IntegrationConnection {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  provider       IntegrationProvider
  status         IntegrationStatus   @default(CONNECTED)

  accessToken    String              @map("access_token") @db.Text
  refreshToken   String?             @map("refresh_token") @db.Text
  tokenExpiresAt DateTime?           @map("token_expires_at")
  scope          String?

  externalTeamId   String?           @map("external_team_id")
  externalTeamName String?           @map("external_team_name")
  metadata         Json?

  connectedBy    String              @map("connected_by")
  connectedAt    DateTime            @default(now()) @map("connected_at")
  disconnectedAt DateTime?           @map("disconnected_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [connectedBy], references: [id])

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@map("integration_connections")
}
